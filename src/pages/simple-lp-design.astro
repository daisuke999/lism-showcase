---
import "lism-css/main.css";
import "@lism-css/ui/style.css";

import {
  Box,
  Center,
  Cluster,
  Columns,
  Container,
  Flex,
  Frame,
  Grid,
  Group,
  Heading,
  Inline,
  Layer,
  Link,
  Lism,
  Media,
  SideMain,
  Stack,
  Text,
} from "lism-css/astro";
import { Accordion, Avatar, Button } from "@lism-css/ui/astro";

const title = "Simple LP Design";

const photos = {
  hero: "https://placehold.co/2000x860/e8ecf4/1e293b/png?text=Hero",
  mission: "https://placehold.co/1400x1050/dbeafe/1e3a8a/png?text=Mission",
  featA: "https://placehold.co/900x900/f1f5f9/334155/png?text=A",
  featB: "https://placehold.co/900x900/f1f5f9/334155/png?text=B",
  point: "https://placehold.co/1000x1333/fef3c7/92400e/png?text=Point",
  serviceMain: "https://placehold.co/1600x900/e2e8f0/0f172a/png?text=Service",
  service1: "https://placehold.co/800x600/e2e8f0/0f172a/png?text=01",
  service2: "https://placehold.co/800x600/e2e8f0/0f172a/png?text=02",
  service3: "https://placehold.co/800x600/e2e8f0/0f172a/png?text=03",
  step: "https://placehold.co/1000x1667/dcfce7/14532d/png?text=Step",
  contactBg: "https://placehold.co/2000x1200/f8fafc/64748b/png?text=Contact",
};

const faqItems = [
  {
    q: "相談から納品までの目安期間はどのくらいですか？",
    a: "案件規模によりますが、ランディングページであればご契約から4〜8週間程度を想定しています。スコープ確定後に詳細スケジュールをご提案します。",
  },
  {
    q: "デザインのみ／実装のみの依頼は可能ですか？",
    a: "可能です。既存デザインのコーディング、既存サイトへの部分導入などもお気軽にご相談ください。",
  },
  {
    q: "対応エリアやリモートワークについて教えてください。",
    a: "オンライン中心で全国対応しています。打ち合わせはビデオ会議を基本とし、必要に応じて対面も調整可能です。",
  },
  {
    q: "料金体系はどうなっていますか？",
    a: "固定費とマイルストーン請求を組み合わせたプランが一般的です。要件整理のうえお見積りいたします。",
  },
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — Lism CSS デモ</title>
    <meta name="description" content="Lism CSS と Astro で構成したランディングページの作例です。" />
  </head>
  <body>
    <Group as="header" pos="sticky" t="0" z="99" bgc="base" bd="bottom" bdc="divider">
      <Container isContainer isWrapper="l">
        <Flex jc="space-between" ai="center" p={["15", "20", "20"]}>
          <Link href="/simple-lp-design" td="none" fz="l" fw="bold" c="text">LISM</Link>
          <Cluster g="20" ai="center" d={["none", "flex", "flex"]}>
            <Link href="#mission" td="none" c="text-2" fz="s">About</Link>
            <Link href="#service" td="none" c="text-2" fz="s">Service</Link>
            <Link href="#voice" td="none" c="text-2" fz="s">Voice</Link>
            <Link href="#faq" td="none" c="text-2" fz="s">FAQ</Link>
            <Button variant="fill" keycolor="text" href="#contact">Contact</Button>
          </Cluster>
        </Flex>
      </Container>
    </Group>

    <main>
      <!-- Hero -->
      <Group as="section" bgc="base-2" p={["40", "50", "60"]} id="top">
        <Container isContainer isWrapper="l">
          <Stack pos="relative" g="30" ai="stretch">
            <Frame ar="21/9" bdrs="30" ov="hidden">
              <Media src={photos.hero} alt="" width={1920} height={823} loading="eager" />
            </Frame>
            <Layer isLayer>
              <Center
                p="30"
                style={{
                  background: "linear-gradient(180deg, hsl(224 4% 8% / 35%) 0%, hsl(224 4% 8% / 55%) 100%)",
                }}
              >
                <Stack g="15" ta="center">
                  <Heading level="1" fz={["2xl", "3xl", "4xl"]} fw="bold" c="white">{title}</Heading>
                  <Text fz="m" c="white" m="0">インテリアをテーマにしたシンプルな LP 構成のサンプルです。</Text>
                </Stack>
              </Center>
            </Layer>
          </Stack>
        </Container>
      </Group>

      <!-- Mission -->
      <Group as="section" bgc="base" p={["50", "60", "70"]} id="mission">
        <Container isContainer isWrapper="l">
          <SideMain sideW="min(32rem, 100%)" mainW="min(0, 1fr)" g={["30", "40", "50"]} ai="stretch">
            <Stack isSide g="20" jc="center">
              <Heading level="2" fz="3xl" fw="bold" m="0">Mission</Heading>
              <Heading level="3" fz="m" fw="normal" c="text-2" m="0">暮らしに寄り添う空間づくり</Heading>
              <Text fz="m" c="text-2" m="0" lh="l">
                素材の質感と光の関係を大切にし、長く愛されるインテリアをご提案します。ここでは Lism CSS の Container・SideMain・Stack
                などを用いて、情報とビジュアルのバランスを取りやすい二段構成にしています。
              </Text>
            </Stack>
            <Frame ar="4/3" bdrs="30" ov="hidden">
              <Media src={photos.mission} alt="" width={1400} height={1050} />
            </Frame>
          </SideMain>
        </Container>
      </Group>

      <!-- Features (alternating) -->
      <Group as="section" bgc="base" p={["0", "0", "20"]}>
        <Container isContainer isWrapper="l">
          <Stack g="50">
            <SideMain sideW="min(22rem, 100%)" mainW="min(0, 1fr)" g={["30", "40", "40"]} ai="center">
              <Frame ar="1/1" bdrs="20" ov="hidden" isSide>
                <Media src={photos.featA} alt="" width={800} height={800} />
              </Frame>
              <Stack g="15">
                <Heading level="3" fz="xl" fw="bold" m="0">素材と光</Heading>
                <Text fz="m" c="text-2" m="0" lh="l">
                  小さな写真とテキストの並びは、SideMain で狭い側を画像に寄せると、本文を読みやすい幅に保ちつつビジュアルも確保しやすくなります。
                </Text>
              </Stack>
            </SideMain>

            <Columns cols={[1, 2]} g={["30", "40", "40"]} ai="center">
              <Stack g="15">
                <Heading level="3" fz="xl" fw="bold" m="0">暮らしのシーン</Heading>
                <Text fz="m" c="text-2" m="0" lh="l">
                  2 行目は文章を先に置き、Columns でカラム数を 1→2 に切り替えています。狭い画面では画像が下に積まれるため、自然に縦読みできます。
                </Text>
              </Stack>
              <Frame ar="1/1" bdrs="20" ov="hidden">
                <Media src={photos.featB} alt="" width={800} height={800} />
              </Frame>
            </Columns>
          </Stack>
        </Container>
      </Group>

      <!-- Point -->
      <Group as="section" bgc="base" p={["50", "60", "70"]} id="point">
        <Container isContainer isWrapper="l">
          <Columns cols={[1, 2]} g={["40", "50", "60"]} ai="start">
            <Stack g="25">
              <Heading level="2" fz="3xl" fw="bold" m="0">Point</Heading>
              <Heading level="3" fz="m" fw="normal" c="text-2" m="0">選ばれる理由</Heading>
              <Stack as="ul" g="30" m="0" p="0" style={{ listStyle: "none" }}>
                <Stack as="li" g="10">
                  <Inline fz="s" fw="bold" c="brand">01</Inline>
                  <Text fz="l" fw="bold" m="0">調和の取れた余白設計</Text>
                  <Text fz="s" c="text-2" m="0" lh="l">トークンに基づく余白で、セクション間のリズムを揃えます。</Text>
                </Stack>
                <Stack as="li" g="10">
                  <Inline fz="s" fw="bold" c="brand">02</Inline>
                  <Text fz="l" fw="bold" m="0">レスポンシブを前提にした段組</Text>
                  <Text fz="s" c="text-2" m="0" lh="l">Columns とコンテナクエリで、レイアウトの切り替えを破綻なく行います。</Text>
                </Stack>
              </Stack>
            </Stack>
            <Frame ar="3/4" bdrs="30" ov="hidden">
              <Media src={photos.point} alt="" width={1000} height={1333} />
            </Frame>
          </Columns>
        </Container>
      </Group>

      <!-- Service -->
      <Group as="section" bgc="base-2" p={["50", "60", "70"]} id="service">
        <Container isContainer isWrapper="l">
          <Stack g="40" ta="center">
            <Stack g="10" ai="center">
              <Heading level="2" fz="3xl" fw="bold" m="0">Service</Heading>
              <Text fz="m" c="text-2" m="0">ご提供メニュー</Text>
            </Stack>

            <SideMain sideW="min(28rem, 100%)" mainW="min(0, 1fr)" g={["30", "40", "50"]} ai="center" ta="left">
              <Frame ar="16/9" bdrs="30" ov="hidden" isSide>
                <Media src={photos.serviceMain} alt="" width={1600} height={900} />
              </Frame>
              <Stack g="15" jc="center">
                <Heading level="3" fz="xl" fw="bold" m="0">トータルコーディネート</Heading>
                <Text fz="m" c="text-2" m="0" lh="l">
                  メインのサービス紹介ブロックです。画像を Side に置き、説明文を Main で可変幅にしています。狭い幅では自動的に縦積みへ切り替わります。
                </Text>
              </Stack>
            </SideMain>

            <Grid gtc={["1fr", "repeat(2, 1fr)", "repeat(3, 1fr)"]} g="30" ta="left">
              <Stack g="15">
                <Frame ar="4/3" bdrs="20" ov="hidden">
                  <Media src={photos.service1} alt="" width={800} height={600} />
                </Frame>
                <Text fz="s" fw="bold" c="text-2" m="0" tt="upper">01 PLANNING</Text>
                <Text fz="m" m="0" lh="l">ヒアリングと現調を踏まえ、プランとスタイル方向性を整理します。</Text>
              </Stack>
              <Stack g="15">
                <Frame ar="4/3" bdrs="20" ov="hidden">
                  <Media src={photos.service2} alt="" width={800} height={600} />
                </Frame>
                <Text fz="s" fw="bold" c="text-2" m="0" tt="upper">02 DESIGN</Text>
                <Text fz="m" m="0" lh="l">家具・照明・素材のバランスを考慮した具体的なデザイン案をご提示します。</Text>
              </Stack>
              <Stack g="15">
                <Frame ar="4/3" bdrs="20" ov="hidden">
                  <Media src={photos.service3} alt="" width={800} height={600} />
                </Frame>
                <Text fz="s" fw="bold" c="text-2" m="0" tt="upper">03 DELIVERY</Text>
                <Text fz="m" m="0" lh="l">発注から設置までを伴走し、完成後のメンテナンス提案までサポートします。</Text>
              </Stack>
            </Grid>
          </Stack>
        </Container>
      </Group>

      <!-- Step -->
      <Group as="section" bgc="base" p={["50", "60", "70"]} id="step">
        <Container isContainer isWrapper="l">
          <SideMain sideW="min(26rem, 100%)" mainW="min(0, 1fr)" g={["30", "40", "50"]} ai="stretch">
            <Frame ar="3/5" bdrs="30" ov="hidden" isSide>
              <Media src={photos.step} alt="" width={1000} height={1667} />
            </Frame>
            <Stack g="25" jc="center">
              <Heading level="2" fz="3xl" fw="bold" m="0">Step</Heading>
              <Heading level="3" fz="m" fw="normal" c="text-2" m="0">ご依頼のながれ</Heading>
              <Stack g="20">
                <Stack g="8" bd="bottom" bdc="divider" p="20">
                  <Text fz="s" fw="bold" c="brand" m="0">Step 01</Text>
                  <Heading level="4" fz="l" fw="bold" m="0">お問い合わせ</Heading>
                  <Text fz="s" c="text-2" m="0" lh="l">フォームまたはメールにて概要をお送りください。</Text>
                </Stack>
                <Stack g="8" bd="bottom" bdc="divider" p="20">
                  <Text fz="s" fw="bold" c="brand" m="0">Step 02</Text>
                  <Heading level="4" fz="l" fw="bold" m="0">ヒアリング</Heading>
                  <Text fz="s" c="text-2" m="0" lh="l">オンラインでライフスタイルとご希望を伺います。</Text>
                </Stack>
                <Stack g="8" p="20">
                  <Text fz="s" fw="bold" c="brand" m="0">Step 03</Text>
                  <Heading level="4" fz="l" fw="bold" m="0">ご提案・契約</Heading>
                  <Text fz="s" c="text-2" m="0" lh="l">お見積りとスケジュールをご提示し、合意後に着手します。</Text>
                </Stack>
              </Stack>
            </Stack>
          </SideMain>
        </Container>
      </Group>

      <!-- Voice -->
      <Group as="section" bgc="base" p={["50", "60", "70"]} id="voice">
        <Container isContainer isWrapper="l">
          <Stack g="40">
            <Stack g="10" ai="center" ta="center">
              <Heading level="2" fz="3xl" fw="bold" m="0">Voice</Heading>
              <Text fz="m" c="text-2" m="0">お客様の声</Text>
            </Stack>
            <Grid gtc={["1fr", "repeat(2, 1fr)", "repeat(3, 1fr)"]} g="30">
              <Box set="shadow" p="30" bdrs="20" bgc="base">
                <Stack g="15" ai="center" ta="center">
                  <Avatar src="https://placehold.co/200x200/e2e8f0/1e293b/png?text=A" alt="" size="64px" />
                  <Stack g="5">
                    <Text fz="m" fw="bold" m="0">佐藤 美咲</Text>
                    <Text fz="xs" c="text-2" m="0">マンションリノベーション</Text>
                  </Stack>
                  <Text fz="s" c="text-2" m="0" lh="l" ta="left">
                    細部の質感までこだわっていただき、写真で見たイメージそのままの空間になりました。
                  </Text>
                </Stack>
              </Box>
              <Box set="shadow" p="30" bdrs="20" bgc="base">
                <Stack g="15" ai="center" ta="center">
                  <Avatar src="https://placehold.co/200x200/e2e8f0/1e293b/png?text=B" alt="" size="64px" />
                  <Stack g="5">
                    <Text fz="m" fw="bold" m="0">田中 誠</Text>
                    <Text fz="xs" c="text-2" m="0">戸建て新築</Text>
                  </Stack>
                  <Text fz="s" c="text-2" m="0" lh="l" ta="left">
                    打ち合わせがスムーズで、予算内に収めながらも満足度の高い提案をいただけました。
                  </Text>
                </Stack>
              </Box>
              <Box set="shadow" p="30" bdrs="20" bgc="base">
                <Stack g="15" ai="center" ta="center">
                  <Avatar src="https://placehold.co/200x200/e2e8f0/1e293b/png?text=C" alt="" size="64px" />
                  <Stack g="5">
                    <Text fz="m" fw="bold" m="0">鈴木 あゆみ</Text>
                    <Text fz="xs" c="text-2" m="0">オフィス移転</Text>
                  </Stack>
                  <Text fz="s" c="text-2" m="0" lh="l" ta="left">
                    ワークスペースの動線が整理され、チームからも好評です。
                  </Text>
                </Stack>
              </Box>
            </Grid>
          </Stack>
        </Container>
      </Group>

      <!-- FAQ -->
      <Group as="section" bgc="base-2" p={["50", "60", "70"]} id="faq">
        <Container isContainer isWrapper="m">
          <Stack g="30">
            <Stack g="10" ai="center" ta="center">
              <Heading level="2" fz="3xl" fw="bold" m="0">FAQ</Heading>
              <Text fz="m" c="text-2" m="0">よくある質問</Text>
            </Stack>
            <Accordion.Root>
              {
                faqItems.map((item) => (
                  <Accordion.Item>
                    <Accordion.Heading>
                      <Accordion.Button>{item.q}</Accordion.Button>
                    </Accordion.Heading>
                    <Accordion.Panel flow="15">
                      <Text m="0" fz="m" c="text-2" lh="l">
                        {item.a}
                      </Text>
                    </Accordion.Panel>
                  </Accordion.Item>
                ))
              }
            </Accordion.Root>
          </Stack>
        </Container>
      </Group>

      <!-- Contact -->
      <Group
        as="section"
        p={["50", "60", "80"]}
        id="contact"
        pos="relative"
        ov="hidden"
        style={{
          backgroundImage: `linear-gradient(hsl(224 4% 99% / 90%), hsl(224 4% 99% / 90%)), url('${photos.contactBg}')`,
          backgroundSize: "cover",
          backgroundPosition: "center",
        }}
      >
        <Container isContainer isWrapper="m">
          <Stack g="30" ai="center">
            <Stack g="10" ai="center" ta="center">
              <Heading level="2" fz="3xl" fw="bold" m="0">Contact</Heading>
              <Text fz="m" c="text-2" m="0">お問い合わせ（デモフォーム）</Text>
            </Stack>
            <Box w="100%" max-sz="s" bgc="base" p="40" bdrs="30" set="shadow">
              <Lism as="form" action="#" method="get">
                <Stack g="25">
                  <Stack g="8">
                    <Lism as="label" fz="s" fw="bold" m="0" d="block" exProps={{ for: "demo-name" }}>Name</Lism>
                    <Lism
                      as="input"
                      id="demo-name"
                      name="name"
                      type="text"
                      bd
                      bdrs="10"
                      p="15"
                      w="100%"
                      fz="m"
                      bgc="base"
                      exProps={{ autocomplete: "name", placeholder: "山田 太郎" }}
                    />
                  </Stack>
                  <Stack g="8">
                    <Lism as="label" fz="s" fw="bold" m="0" d="block" exProps={{ for: "demo-email" }}>Email</Lism>
                    <Lism
                      as="input"
                      id="demo-email"
                      name="email"
                      type="email"
                      bd
                      bdrs="10"
                      p="15"
                      w="100%"
                      fz="m"
                      bgc="base"
                      exProps={{ autocomplete: "email", placeholder: "you@example.com" }}
                    />
                  </Stack>
                  <Stack g="8">
                    <Lism as="label" fz="s" fw="bold" m="0" d="block" exProps={{ for: "demo-msg" }}>Message</Lism>
                    <Lism
                      as="textarea"
                      id="demo-msg"
                      name="message"
                      bd
                      bdrs="10"
                      p="15"
                      w="100%"
                      fz="m"
                      bgc="base"
                      min-h="10rem"
                      exProps={{ rows: 5, placeholder: "ご用件をご記入ください" }}
                    />
                  </Stack>
                  <Lism
                    as="button"
                    type="submit"
                    lismClass="c--button"
                    variant="fill"
                    keycolor="text"
                    w="100%"
                    ta="center"
                    fz="m"
                    fw="bold"
                    bdrs="10"
                    p="15"
                    m="0"
                  >
                    送信する
                  </Lism>
                </Stack>
              </Lism>
            </Box>
          </Stack>
        </Container>
      </Group>
    </main>

    <Group as="footer" bgc="base-2" p="30" bd="top" bdc="divider">
      <Container isContainer isWrapper="l">
        <Flex jc="space-between" ai="center" g="20" fxd={["column", "row", "row"]}>
          <Link href="/simple-lp-design" td="none" fz="m" fw="bold" c="text">LISM</Link>
          <Text fz="xs" c="text-2" m="0">© {new Date().getFullYear()} Lism Showcase. All rights reserved.</Text>
        </Flex>
      </Container>
    </Group>
  </body>
</html>
