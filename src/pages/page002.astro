---
import DemoLayout from '@/layouts/DemoLayout.astro';
import { Container, Wrapper } from 'lism-css/astro';
import Header from '@/components/page002/Header.astro';
import MV from '@/components/page002/MV.astro';
import Mission from '@/components/page002/Mission.astro';
import Mission2 from '@/components/page002/Mission2.astro';
import Footer from '@/components/page002/Footer.astro';
import Feature from '@/components/page002/Feature.astro';
import Service from '@/components/page002/Service.astro';
import Step from '@/components/page002/Step.astro';
import Voice from '@/components/page002/Voice.astro';
import FAQ from '@/components/page002/FAQ.astro';
import Contact from '@/components/page002/Contact.astro';

export const title = 'page002：Simple Natural LP Design';
---

<DemoLayout title={title}>
  <Wrapper contentSize='full'>
    <!-- Header -->
    <Header />
    <!-- Main Content -->
    <Container as='main' class='z--main' pos='relative' z='0'>
      <MV />
      <Mission />
      <Mission2 />
      <Feature />
      <Service />
      <Step />
      <Voice />
      <FAQ />
      <Contact />
    </Container>
    <!-- Footer -->
    <Footer />
  </Wrapper>
</DemoLayout>

<style>
  /* Root */
  :root {
    --z--header-height: 112px;
    --z--header-height--thin: 64px;
    --u--fadeIn--animation-range: entry 0% contain 20%;
    /* color token */
    --base-2: #ececec;
  }
  /* Fadein */
  .u--fadeIn {
    view-timeline: --u--fadeIn y;
    animation: u--fadeIn linear both;
    animation-timeline: --u--fadeIn;
    animation-range: var(--u--fadeIn--animation-range);
  }
  @keyframes u--fadeIn {
    from {
      opacity: 0;
      transform: translateY(32px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  /* Background Parallax */
  .u--bgParallax {
    view-timeline: --u--bgParallax y;
  }
  .u--bgParallax .a--media {
    position: absolute;
    top: -20%;
    height: 140%;
    animation: u--bgParallax_media linear both;
    animation-timeline: --u--bgParallax;
    animation-range: entry 0% cover 100%;
  }
  @keyframes u--bgParallax_media {
    from {
      transform: translateY(-10%);
    }
    to {
      transform: translateY(10%);
    }
  }
</style>
