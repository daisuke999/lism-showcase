---
import 'lism-css/main.css';
import { Link, Stack, Text } from 'lism-css/astro';

type PageModule = { title?: string };
type PageLink = { href: string; label: string };

const devModules = import.meta.glob<PageModule>('./*.astro', { eager: true });
const mergedModules = import.meta.glob<PageModule>('./merged/*/index.astro', { eager: true });

function slugToLabel(slug: string): string {
  return slug
    .split('-')
    .filter(Boolean)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

function normalizeLabel(mod: PageModule | undefined, fallbackSlug: string): string {
  if (typeof mod?.title === 'string' && mod.title.trim().length > 0) {
    return mod.title.trim();
  }
  return slugToLabel(fallbackSlug);
}

function collectDevPageLinks(source: Record<string, PageModule>): PageLink[] {
  const links: PageLink[] = [];
  for (const filePath of Object.keys(source).sort()) {
    if (filePath === './index.astro') continue;
    const fileName = filePath.split('/').pop() ?? '';
    if (!fileName || fileName.startsWith('_')) continue;
    const slug = fileName.replace(/\.astro$/i, '');
    if (!slug || slug.includes('[') || slug.includes(']')) continue;

    links.push({
      href: `/${slug}`,
      label: normalizeLabel(source[filePath], slug),
    });
  }
  return links;
}

function collectMergedPageLinks(source: Record<string, PageModule>): PageLink[] {
  const links: PageLink[] = [];
  for (const filePath of Object.keys(source).sort()) {
    const m = filePath.match(/\/merged\/([^/]+)\/index\.astro$/);
    if (!m) continue;
    const slug = m[1];
    links.push({
      href: `/merged/${slug}`,
      label: normalizeLabel(source[filePath], slug),
    });
  }
  return links;
}

const pageLinks = collectDevPageLinks(devModules as Record<string, PageModule>);
const mergedPageLinks = collectMergedPageLinks(mergedModules as Record<string, PageModule>);
---

<html lang='ja'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width' />
    <title>Lism Showcase</title>
  </head>
  <body>
    <Stack p='40' g='20'>
      <h1>Lism Showcase</h1>
      <Text m='0' fz='l' fw='600'> マージ前（開発用） </Text>
      {
        pageLinks.map(({ href, label }) => (
          <Text m='0'>
            <Link href={href}>{label}</Link>
          </Text>
        ))
      }
      <Text m='0' mt='30' fz='l' fw='600'> マージ後（テンプレ1ファイル） </Text>
      {
        mergedPageLinks.map(({ href, label }) => (
          <Text m='0'>
            <Link href={href}>{label}</Link>
          </Text>
        ))
      }
    </Stack>
  </body>
</html>
