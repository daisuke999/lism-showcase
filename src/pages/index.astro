---
import 'lism-css/main.css';
import { Link, Stack, Text } from 'lism-css/astro';

import { title as titleDevLp001 } from './lp001.astro';
import { title as titleDevLp002 } from './lp002.astro';
import { title as titleDevLp003 } from './lp003.astro';
import { title as titleSkillGenerateTest } from './skill-generate-test.astro';

import { title as titleMergedLp001 } from './merged/lp001/index.astro';
import { title as titleMergedLp002 } from './merged/lp002/index.astro';
import { title as titleMergedLp003 } from './merged/lp003/index.astro';

type PageLink = { href: string; label: string };

/** マージ前：ラベルは各ページの `export const title` をそのまま表示する */
const pageLinks: PageLink[] = [
  { href: '/lp001', label: titleDevLp001 },
  { href: '/lp002', label: titleDevLp002 },
  { href: '/lp003', label: titleDevLp003 },
  { href: '/skill-generate-test', label: titleSkillGenerateTest },
];

/** マージ後：ラベルは各 `merged/lp00x/index.astro` の `export const title` をそのまま表示する */
const mergedPageLinks: PageLink[] = [
  { href: '/merged/lp001', label: titleMergedLp001 },
  { href: '/merged/lp002', label: titleMergedLp002 },
  { href: '/merged/lp003', label: titleMergedLp003 },
];
---

<html lang='ja'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width' />
    <title>Lism Showcase</title>
  </head>
  <body>
    <Stack p='40' g='20'>
      <h1>Lism Showcase</h1>
      <Text m='0' fz='l' fw='600'> マージ前（開発用） </Text>
      {
        pageLinks.map(({ href, label }) => (
          <Text m='0'>
            <Link href={href}>{label}</Link>
          </Text>
        ))
      }
      <Text m='0' mt='30' fz='l' fw='600'> マージ後（テンプレ1ファイル） </Text>
      {
        mergedPageLinks.map(({ href, label }) => (
          <Text m='0'>
            <Link href={href}>{label}</Link>
          </Text>
        ))
      }
    </Stack>
  </body>
</html>
