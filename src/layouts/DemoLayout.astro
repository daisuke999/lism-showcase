---
interface Props {
  title: string;
}

const { title } = Astro.props;

import 'lism-css/main.css';
import '@lism-css/ui/style.css';
---

<!doctype html>
<html lang='ja'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <title>{title}</title>
    <slot name='head' />
  </head>
  <body>
    <slot />
  </body>
</html>
