---
import { Stack, Flex, Heading, Text, Box, Container, AutoColumns } from 'lism-css/astro';
import { Avatar } from '@lism-css/ui/astro';

/**
 * アバター画像（Lism 公式ドキュメントの Avatar 例と同じ CDN パス）
 * @see https://lism-css.com/docs/ui/avatar/
 */
const avatarBase = 'https://cdn.lism-css.com/img/avatar';

type VoiceCard = {
  avatar: { src: string; alt: string };
  title: string;
  body: string;
  attribution: string;
};

const voiceCards: VoiceCard[] = [
  {
    avatar: { src: `${avatarBase}/a-01.jpg`, alt: '笑顔の女性のポートレート' },
    title: '素晴らしいです！',
    body: '静けさの贅沢と、誰にも邪魔されないプライベートな時間を味わえました。お部屋付きの露天風呂も最高で、心からリフレッシュできました。また必ず伺いたいです。',
    attribution: '20代のお客様',
  },
  {
    avatar: { src: `${avatarBase}/a-02.jpg`, alt: '穏やかな表情の男性のポートレート' },
    title: '心から満足しています',
    body: 'フロントの対応が丁寧で、細かなリクエストにも快く応じていただけました。お食事のボリュームと味のバランスが絶妙で、旅のハイライトになりました。',
    attribution: '30代のお客様',
  },
  {
    avatar: { src: `${avatarBase}/a-03.jpg`, alt: '柔らかい印象の女性のポートレート' },
    title: 'また家族で来たいです',
    body: '子ども連れでも過ごしやすい動線と、落ち着いた雰囲気が両立していました。夕方の散策路から望む景色も忘れられず、写真に収めきれない美しさでした。',
    attribution: '40代のお客様',
  },
  {
    avatar: { src: `${avatarBase}/a-04.jpg`, alt: '爽やかな笑みの女性のポートレート' },
    title: '非日常を味わえました',
    body: '内装の質感やアメニティの選び方にこだわりを感じます。朝の光が差し込むラウンジでのひとときは、本を読むのにも最適でした。',
    attribution: '50代のお客様',
  },
  {
    avatar: { src: `${avatarBase}/a-02.jpg`, alt: '記念日にご宿泊のお客様のポートレート' },
    title: '記念日にぴったりでした',
    body: 'サプライズの相談から当日の演出まで、安心してお任せできました。料理の説明も分かりやすく、ワインとのペアリングも楽しめました。',
    attribution: '60代のお客様',
  },
  {
    avatar: { src: `${avatarBase}/a-02.jpg`, alt: '記念日にご宿泊のお客様のポートレート' },
    title: '記念日にぴったりでした',
    body: 'サプライズの相談から当日の演出まで、安心してお任せできました。料理の説明も分かりやすく、ワインとのペアリングも楽しめました。',
    attribution: '60代のお客様',
  },
];
---

<Box as='section' class='z--page002-voice' bgc='base'>
  <Container isWrapper='l' hasGutter py='50' isContainer>
    <Stack g='30'>
      <Stack g='10' ai='c'>
        <Heading level='2' fz='4xl' lts='l' m='0' ta='center'>Voice</Heading>
        <Text as='p' fz='m' fw='bold' lts='l' m='0' c='text-2' ta='center'>お客様の声です</Text>
      </Stack>

      {
        /**
         * md 未満: Flex + hasSnap（公式 Reel の Flex 例と同型。Grid の gaf:column は縦積みになりやすい）
         * md 以上: AutoColumns（最小幅 24rem、折り返し）
         * @see https://lism-css.com/docs/ui/examples/reel/
         * @see https://lism-css.com/docs/primitives/l--autoColumns/
         */
      }
      <Box class='z--page002-voice_layout' min-w='0' w='100%'>
        <Flex
          class='z--page002-voice_reel'
          hasSnap
          ov='auto'
          g='20'
          fxd='row'
          fxw='nowrap'
          ai='stretch'
          w='100%'
          min-w='0'
          tabindex={0}
        >
          {
            voiceCards.map((card) => (
              <Box
                class='z--page002-voice_card z--page002-voice_slide'
                p='30'
                bgc='base'
                bd
                bdc='divider'
                bdrs='20'
                fxsh='0'
                min-w='0'
                min-h='0'
                d='flex'
                fxd='column'
                aslf='stretch'
              >
                <Stack g='20' ai='stretch' fx='1' min-h='0' jc='start'>
                  <Avatar src={card.avatar.src} alt={card.avatar.alt} size='5.5rem' mx='auto' />
                  <Heading level='3' fz='l' fw='bold' m='0' ta='center'>
                    {card.title}
                  </Heading>
                  <Text as='p' fz='s' m='0' c='text' lh='l' ta='left'>
                    {card.body}
                  </Text>
                  <Text
                    class='z--page002-voice_attribution'
                    as='p'
                    fz='xs'
                    m='0'
                    c='text-2'
                    o='p'
                    ta='end'
                    w='100%'
                    mt='auto'
                  >
                    {card.attribution}
                  </Text>
                </Stack>
              </Box>
            ))
          }
        </Flex>

        <AutoColumns class='z--page002-voice_auto' cols='24rem' g='30' w='100%' min-w='0'>
          {
            voiceCards.map((card) => (
              <Box
                class='z--page002-voice_card'
                p='30'
                bgc='base'
                bd
                bdc='divider'
                bdrs='20'
                min-w='0'
                d='flex'
                fxd='column'
                h='100%'
              >
                <Stack g='20' ai='stretch' fx='1' min-h='0' jc='start'>
                  <Avatar src={card.avatar.src} alt={card.avatar.alt} size='5.5rem' mx='auto' />
                  <Heading level='3' fz='l' fw='bold' m='0' ta='center'>
                    {card.title}
                  </Heading>
                  <Text as='p' fz='s' m='0' c='text' lh='l' ta='left'>
                    {card.body}
                  </Text>
                  <Text
                    class='z--page002-voice_attribution'
                    as='p'
                    fz='xs'
                    m='0'
                    c='text-2'
                    o='p'
                    ta='end'
                    w='100%'
                    mt='auto'
                  >
                    {card.attribution}
                  </Text>
                </Stack>
              </Box>
            ))
          }
        </AutoColumns>
      </Box>
    </Stack>
  </Container>
</Box>

<style>
  @layer lism-component {
    /**
     * 横リール: 中央スナップ（has--snap の子へ --snapAlign が効く）
     * @see https://lism-css.com/ui/examples/reel/
     */
    .z--page002-voice_reel {
      --snapType: x mandatory;
      --snapAlign: center;
      align-items: stretch;
    }

    /* 行内で最も高いカードに合わせてスライドの高さを揃える（h:100% は未定義高さで stretch を阻害しやすい） */
    .z--page002-voice_slide {
      flex: 0 0 min(24rem, 85%);
      align-self: stretch;
      height: auto;
    }

    .z--page002-voice_auto {
      display: none;
    }

    @container (min-width: 800px) {
      .z--page002-voice_reel {
        display: none !important;
        overflow: visible;
      }

      .z--page002-voice_auto {
        display: grid;
      }
    }
  }
</style>
