---
import { Frame, Stack, Container, Layer, Box, Text, Heading, Lism } from 'lism-css/astro';

const bgImage = {
  src: 'https://cdn.lism-css.com/img/room/a-Rrr1UZO5Ji.jpg',
  alt: '明るい室内のワークスペース',
  width: 1920,
  height: 1080,
};

/** 各フィールドの表示・name・プレースホルダーを独立して管理 */
type ContactField =
  | {
      id: string;
      name: string;
      label: string;
      type: 'text' | 'email';
      placeholder: string;
      inputMode?: 'email' | 'text';
      autoComplete?: string;
    }
  | {
      id: string;
      name: string;
      label: string;
      type: 'textarea';
      placeholder: string;
      rows: number;
    };

const contactFields: ContactField[] = [
  {
    id: 'page002-contact-name',
    name: 'name',
    label: '名前',
    type: 'text',
    placeholder: '鈴木 太郎',
    autoComplete: 'name',
  },
  {
    id: 'page002-contact-email',
    name: 'email',
    label: 'メールアドレス',
    type: 'email',
    placeholder: 'example@lism.com',
    inputMode: 'email',
    autoComplete: 'email',
  },
  {
    id: 'page002-contact-subject',
    name: 'subject',
    label: '件名',
    type: 'text',
    placeholder: 'ご宿泊について',
    autoComplete: 'off',
  },
  {
    id: 'page002-contact-message',
    name: 'message',
    label: '問い合わせ内容',
    type: 'textarea',
    placeholder: 'お問い合わせ内容はこちらにご記入ください。',
    rows: 6,
  },
];
---

<Box as='section' class='c--contact' pos='relative' ov='hidden'>
  <Frame isLayer class='c--contactMediaWrap'>
    <Lism
      as='img'
      class='c--contactMedia'
      src={bgImage.src}
      alt={bgImage.alt}
      w='100%'
      h='100%'
      exProps={{ width: bgImage.width, height: bgImage.height, loading: 'lazy', decoding: 'async' }}
    />
  </Frame>
  <!-- Feature.astro と同様の重ね構造。完全白黒ではなく filter + HSL オーバーレイでうっすら色を残す -->
  <Layer
    pos='absolute'
    exProps={{
      style: {
        inset: 0,
        pointerEvents: 'none',
        backgroundImage:
          'linear-gradient(180deg, hsl(215 26% 96% / 0.72) 0%, hsl(215 22% 22% / 0.48) 100%)',
      },
    }}
  />
  <Container class='c--contactInner' size='l' set='gutter' py='60' pos='relative'>
    <Stack g='40' ai='c'>
      <Stack g='12' ai='c' max-w='36rem' w='100%'>
        <Heading level='2' fz='3xl' lts='l' m='0' ta='center' c='white'>Contact</Heading>
        <Text as='p' fz='m' fw='bold' lts='l' m='0' c='white' ta='center'>お問い合わせ</Text>
        <Text as='p' fz='s' m='0' c='white' ta='center' lh='l'>
          初めての方もどうぞお気軽にお問い合わせください。
        </Text>
      </Stack>

      <Box as='form' class='c--contactForm' max-w='36rem' w='100%' method='post' action='#'>
        <Stack g='24'>
          {
            contactFields.map((field) => (
              <Stack g='8' ai='stretch'>
                <Lism as='label' for={field.id} fz='s' fw='bold' m='0' c='white'>
                  {field.label}
                </Lism>
                {field.type === 'textarea' ? (
                  <textarea
                    id={field.id}
                    class='c--contactInput c--contactInput--textarea'
                    name={field.name}
                    rows={field.rows}
                    placeholder={field.placeholder}
                  />
                ) : (
                  <input
                    id={field.id}
                    class='c--contactInput'
                    name={field.name}
                    type={field.type}
                    placeholder={field.placeholder}
                    inputmode={field.inputMode}
                    autocomplete={field.autoComplete}
                  />
                )}
              </Stack>
            ))
          }
          <button type='submit' class='c--contactSubmit'>お問い合わせ</button>
        </Stack>
      </Box>
    </Stack>
  </Container>
</Box>

<style>
  @layer lism-modules {
    .c--contact {
      min-height: min(88vh, 52rem);
    }

    .c--contactMediaWrap {
      position: absolute;
      inset: 0;
    }

    .c--contactMedia {
      display: block;
      object-fit: cover;
      width: 100%;
      height: 100%;
      /* 完全な grayscale(1) ではなく、彩度を少し残す */
      filter: grayscale(0.55) saturate(0.72) contrast(0.96) brightness(1.02);
    }

    .c--contactInput {
      box-sizing: border-box;
      width: 100%;
      margin: 0;
      padding: var(--s15) var(--s20);
      font: inherit;
      font-size: var(--fz--s);
      line-height: calc(1em + var(--hl) * 2);
      color: var(--text);
      background-color: var(--base);
      border: 1px solid var(--divider);
      border-radius: var(--bdrs--20);
      box-shadow: var(--sh--5);
    }

    .c--contactInput::placeholder {
      color: var(--text-2);
      opacity: 0.85;
    }

    .c--contactInput:focus-visible {
      outline: 2px solid var(--brand);
      outline-offset: 2px;
    }

    .c--contactInput--textarea {
      min-height: 10rem;
      resize: vertical;
    }

    .c--contactSubmit {
      box-sizing: border-box;
      width: 100%;
      margin: 0;
      margin-block-start: var(--s10);
      padding: var(--s15) var(--s30);
      font: inherit;
      font-size: var(--fz--m);
      font-weight: var(--fw--bold);
      letter-spacing: var(--lts--l);
      color: var(--base);
      cursor: pointer;
      background-color: hsl(220 10% 20%);
      border: none;
      border-radius: var(--bdrs--99);
      box-shadow: var(--sh--10);
    }

    .c--contactSubmit:hover {
      opacity: 0.92;
    }

    .c--contactSubmit:focus-visible {
      outline: 2px solid var(--base);
      outline-offset: 3px;
    }
  }
</style>
