---
import {
  Stack,
  Container,
  Icon,
  Cluster,
  Text,
  Inline,
  Box,
  Frame,
  Media,
  Heading,
  Wrapper,
  Grid,
} from 'lism-css/astro';
---

<Wrapper contentSize='l' py='50' hasGutter>
  <Stack g='40'>
    <Grid gta={[`'.' 'side'`, null, `'side .'`]} gtc={[null, null, '24rem 1fr']} ai='c' g='40'>
      <Stack g='20'>
        <Heading level='3' fz='2xl' lts='l'>特徴を述べます</Heading>
        <Text
          >Lorem ipsum dolor sit amet. Consectetur adipiscing elit, sed do eiusmod tempor Incididunt ut. Labore et
          dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut.</Text
        >
      </Stack>
      <Frame ga='side' ar='4/3'>
        <Media
          src='https://placehold.co/1000x1000/e2e8f0/0f172a/png?text=Mission'
          alt='Mission'
          width={1000}
          height={1000}
        />
      </Frame>
    </Grid>
    <Grid gta={[`'.' 'side'`, null, `'. side'`]} gtc={[null, null, '1fr 24rem']} ai='c' g='40'>
      <Stack ai={[null, null, 'end']} g='20'>
        <Heading level='3' fz='2xl' lts='l'>特徴を述べます</Heading>
        <Text>
          Lorem ipsum dolor sit amet. Consectetur adipiscing elit, sed do eiusmod tempor Incididunt ut. Labore et dolore
          magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut.</Text
        >
      </Stack>
      <Frame ga='side' ar='4/3'>
        <Media
          src='https://placehold.co/1000x1000/e2e8f0/0f172a/png?text=Mission'
          alt='Mission'
          width={1000}
          height={1000}
        />
      </Frame>
    </Grid>
  </Stack>
</Wrapper>

