---
import { Lism, Stack, Flex, Frame, Heading, Text } from 'lism-css/astro';

const missionImage = {
  src: 'https://cdn.lism-css.com/img/room/u-MojU9rQhZn.jpg',
  alt: '日差しの入るリビング。ソファ、ラグ、大きな窓と観葉植物のある室内',
  width: 1920,
  height: 1280,
} as const;

const body =
  '暮らしの形は、家族構成も予算も理想もそれぞれ違います。LISM Lifeは、賃貸でも戸建てでも、日々の暮らし方や悩みを丁寧にお伺いし、家具の選び方からコーディネート、必要に応じた配置やお手伝いまでを一貫して支えます。雑誌の切り抜きがなくても、イメージのかけらから具体的な部屋づくりへと一緒に形にします。小さな相談と本格的な部屋作り、どちらも「自分らしい住みよさ」へつながる一歩になればと考えています。';
---

<Lism as='section' id='mission' isContainer class='z--p002-mission' pos='relative' py='50' my-s='60' ov='hidden'>
  <Lism class='z--p002-mission_bg' exProps={{ 'aria-hidden': 'true' }} />
  <Flex
    fxd={['column', null, 'row']}
    ai={['start', null, 'stretch']}
    g={['40', null, '50']}
    pos='relative'
    z='1'
    w='100%'
  >
    <Flex class='z--p002-mission_text' fxd='column' ai='start' min-w='0' w='100%'>
      <Stack g='30' ai='start'>
        <Stack g='10' ai='start'>
          <Heading level='2' m='0' fz='5xl' fw='bold' lts='l' c='text' ff='accent'> Mission </Heading>
          <Text as='p' m='0' fz='xl' fw='bold' lts='l' c='text'> 私たちが目指すもの </Text>
        </Stack>
        <Text as='p' m='0' fz='m' lh='l' lts='s' c='text-2'>
          {body}
        </Text>
      </Stack>
    </Flex>
    <!-- Frame 本体に padding すると l--frame のトークンと競合しやすいため、拡縮用ラッパーに右ガターを乗せる -->
    <Lism class='z--p002-mission_figureShell' min-w='0' w='100%'>
      <Frame
        as='figure'
        class='z--p002-mission_figure'
        m='0'
        w='100%'
        min-w='0'
        jslf='start'
        ar='3/2'
        ov='hidden'
        pos='relative'
      >
        <img
          src={missionImage.src}
          width={missionImage.width}
          height={missionImage.height}
          alt={missionImage.alt}
          loading='lazy'
          decoding='async'
          class='z--p002-mission_img'
        />
      </Frame>
    </Lism>
  </Flex>
</Lism>

<style>
  @layer lism-component {
    /* l 左: ビュー基準。右端（xl 相当）: 子孫で 100cqi＝#mission 幅 main 内でも正しい */
    .z--p002-mission {
      --_mission-l-pad: max(var(--gutter-size, var(--s30)), calc((100vw - min(100vw, var(--sz--l, 1280px))) / 2));
    }
    .z--p002-mission_bg {
      position: absolute;
      inset-block: 0;
      z-index: 0;
      right: 0;
      background-color: var(--base-2, #ececec);
      pointer-events: none;
    }
    @container (min-width: 800px) {
      .z--p002-mission_bg {
        left: calc(var(--_mission-l-pad) + 10rem);
      }
    }
    @container not (min-width: 800px) {
      .z--p002-mission_bg {
        left: 10rem;
      }
    }
    .z--p002-mission_text {
      position: relative;
      z-index: 1;
      box-sizing: border-box;
      max-width: 100%;
      padding-inline-start: var(--_mission-l-pad);
    }
    @container (min-width: 800px) {
      .z--p002-mission_text {
        flex: 1 1 0;
        min-width: 0;
        padding-inline-end: var(--s20);
        /* 行内で交差軸に伸長（min-h:auto 由来の上寄せに縛られない）→ 主軸方向の center が効く */
        align-self: stretch;
        justify-content: center;
      }
    }
    .z--p002-mission_figure {
      box-sizing: border-box;
    }
    .z--p002-mission_figureShell {
      position: relative;
      z-index: 1;
      box-sizing: border-box;
    }
    @container (min-width: 800px) {
      .z--p002-mission_figureShell {
        flex: 1 1 0;
        padding-inline-end: max(
          1.25rem,
          var(--gutter-size, var(--s30)),
          calc((100cqi - min(100cqi, var(--sz--xl, 90rem))) / 2)
        );
      }
    }
    @container not (min-width: 800px) {
      .z--p002-mission_text {
        justify-content: flex-start;
        padding-inline-end: max(
          1.25rem,
          var(--gutter-size, var(--s30)),
          calc((100cqi - min(100cqi, var(--sz--xl, 90rem))) / 2)
        );
      }
      .z--p002-mission_figureShell {
        padding-inline-start: var(--_mission-l-pad);
        padding-inline-end: max(
          1.25rem,
          var(--gutter-size, var(--s30)),
          calc((100cqi - min(100cqi, var(--sz--xl, 90rem))) / 2)
        );
      }
    }
    .z--p002-mission_img {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }
</style>
