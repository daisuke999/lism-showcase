---
import { Stack, Container, Box, BoxLink, Icon, Cluster, Text, Flex, Link, ListItem } from 'lism-css/astro';
---

<Box as='footer' class='z--footer' bgc='base-2' w='100%'>
  <Container class='z--footer_container' isContainer isWrapper='xl' py='40' hasGutter>
    <Stack jc='c' ai='c' g='30'>
      <Stack class='z--header_logo'>
        <Link class='z--header_logoLink' href='#top' fz='2xl' fw='bold' lts='l' c='text' td='none' ff='accent'>
          LISM Life
        </Link>
      </Stack>
      <Flex
        as='ul'
        class='z--footerNav z--headerNav'
        fxd={['column', 'column', 'row']}
        ai={['stretch', 'stretch', 'c']}
        jc={['start', 'start', 'c']}
        fxw={['nowrap', 'nowrap', 'wrap']}
        g={['0', '0', '30']}
        w={['100%', '100%', 'auto']}
        min-w='0'
        fz='s'
        lts='l'
        m='0'
        p='0'
      >
        <ListItem>
          <Link
            class='z--headerNav_link'
            href='#mission'
            d='block'
            c='text'
            td='none'
            w={['100%', '100%', 'auto']}
            py={['15', '15', '10']}
            hasTransition
            hov='-o'
          >
            ミッション
          </Link>
        </ListItem>
        <ListItem>
          <Link
            class='z--headerNav_link'
            href='#feature'
            d='block'
            c='text'
            td='none'
            w={['100%', '100%', 'auto']}
            py={['15', '15', '10']}
            hasTransition
            hov='-o'
          >
            特長
          </Link>
        </ListItem>
        <ListItem>
          <Link
            class='z--headerNav_link'
            href='#service'
            d='block'
            c='text'
            td='none'
            w={['100%', '100%', 'auto']}
            py={['15', '15', '10']}
            hasTransition
            hov='-o'
          >
            サービス
          </Link>
        </ListItem>
        <ListItem>
          <Link
            class='z--headerNav_link'
            href='#step'
            d='block'
            c='text'
            td='none'
            w={['100%', '100%', 'auto']}
            py={['15', '15', '10']}
            hasTransition
            hov='-o'
          >
            ご依頼の流れ
          </Link>
        </ListItem>
        <ListItem>
          <Link
            class='z--headerNav_link'
            href='#voice'
            d='block'
            c='text'
            td='none'
            w={['100%', '100%', 'auto']}
            py={['15', '15', '10']}
            hasTransition
            hov='-o'
          >
            お客様の声
          </Link>
        </ListItem>
      </Flex>
      <Cluster g='20'>
        <BoxLink href='#' hov='-o'>
          <Icon icon='logo-x' fz='xl' c='text-2' />
        </BoxLink>
        <BoxLink href='#' hov='-o'>
          <Icon icon='logo-instagram' fz='xl' c='text-2' />
        </BoxLink>
        <BoxLink href='#' hov='-o'>
          <Icon icon='logo-youtube' fz='xl' c='text-2' />
        </BoxLink>
        <BoxLink href='#' hov='-o'>
          <Icon icon='logo-line' fz='xl' c='text-2' />
        </BoxLink>
      </Cluster>
      <Text as='p' fz='s' c='text-2' m='0'>© 2026 LISM Life.</Text>
    </Stack>
  </Container>
</Box>

<style>
  .z--footerNav {
    list-style: none;
  }

  .z--footerNav :global(.z--headerNav_link) {
    text-align: center;
  }
  @container (min-width: 800px) {
    .z--footerNav :global(.z--headerNav_link) {
      text-align: start;
    }
  }

  /* md 未満: 縦並びの項目間に区切り（最後の行の下には付けない） */
  .z--footerNav > :global(li:not(:last-child)) {
    border-block-end: 1px solid var(--divider);
  }

  @container (min-width: 800px) {
    .z--footerNav > :global(li:not(:last-child)) {
      border-block-end: none;
    }
  }
</style>
