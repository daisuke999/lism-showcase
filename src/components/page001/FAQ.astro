---
import { Stack, Container, Text } from "lism-css/astro";
import { Accordion } from "@lism-css/ui/astro";
import HGroup from "@/components/page001/HGroup.astro";

/** 各項目は質問・回答とも別テキストを想定 */
const faqItems: { question: string; answer: string }[] = [
  {
    question: "Lism CSSとは何ですか？",
    answer:
      "AIと人の両方が読み解きやすい命名と、レイアウトプリミティブ・デザイントークン・ユーティリティを一体で扱うCSS設計フレームワークです。軽量でビルド不要な導入も可能です。",
  },
  {
    question: "他のCSSフレームワークとの違いは？",
    answer:
      "ハーモニックスケールに沿った余白・タイポ、Property Classの短い表記、@layerによるレイヤー設計が中心です。公式サイトの「概要」で思想と用語の全体像を確認できます。",
  },
  {
    question: "ReactやAstroでも使えますか？",
    answer:
      "はい。lism-css/react や lism-css/astro からコンポーネントをインポートして利用できます。UIパッケージ（Accordion など）も同じ流れで組み込めます。",
  },
  {
    question: "商用プロジェクトで利用できますか？",
    answer:
      "パッケージのライセンスに従ってご利用ください。既存のデザインルールやアクセシビリティ方針とあわせ、トークン設計と運用ルールだけ先にすり合わせるのが安全です。",
  },
  {
    question: "カスタマイズや独自スタイルはどこに書けばよいですか？",
    answer:
      "Lismにない演出やページ固有の調整は、プロジェクトの@layer方針に沿ってモジュールクラスやページローカルのstyleへ寄せるのがおすすめです。詳細はCustomizeの項目を参照してください。",
  },
  {
    question: "不具合や要望はどこに報告すればよいですか？",
    answer:
      "GitHubのIssueなど、リポジトリに記載の連絡手段へお願いします。再現手順・環境・期待する表示を添えると、再現と優先付けがしやすくなります。",
  },
];
---

<Container id="faq" class="z--faq" isWrapper="m" py="60" hasGutter>
  <Stack g="40">
    <HGroup text="FAQ" subText="よくある質問" />
    <Accordion.Root class="u--divide" p="0" ov="clip">
      {
        faqItems.map((item) => (
          <Accordion.Item>
            <Accordion.Heading p="30">
              <Accordion.Button>{item.question}</Accordion.Button>
            </Accordion.Heading>
            <Accordion.Panel py="30" px="30">
              <Text m="0">{item.answer}</Text>
            </Accordion.Panel>
          </Accordion.Item>
        ))
      }
    </Accordion.Root>
  </Stack>
</Container>

<style>
  .z--faq .c--accordion {
    view-timeline: --z-faq_accordion y;
    animation: u--fadeIn linear both;
    animation-timeline: --z-faq_accordion;
    animation-range: var(--u--fadeIn--animation-range);
  }
  @media (any-hover: hover) {
    .-hov\:in\:underline {
      text-decoration: var(--_isHov, underline);
    }
  }
</style>
