---
import { Stack, Container, BoxLink, Frame, Layer, Box, Text, Inline, Lism } from "lism-css/astro";
import HGroup from "@/components/page001/HGroup.astro";

const bg = {
  src: "https://cdn.lism-css.com/img/random-2510?r=news",
  alt: "",
  width: 960,
  height: 640,
};

const newsRows = [
  {
    date: "2026.03.18",
    title: "Lism UI：TabsとDrawerの挙動を更新",
    summary:
      "キーボード操作とフォーカス管理を中心に改善し、Astro／React双方で同じAPI感に近づけました。既存プロジェクトは移行ガイドのチェックリストを参照してください。",
    long: true,
  },
  {
    date: "2026.02.04",
    title: "MCPサーバー：ドキュメント検索の応答を高速化",
    summary: "キャッシュ方針を見直し、よく参照されるページ（レイアウトプリミティブ／Customize）の取得を最適化しました。",
    long: false,
  },
  {
    date: "2026.01.22",
    title: "テンプレート集にブログ詳細レイアウトを追加",
    summary:
      "目次・引用・コードブロックのスタイルをテンプレート化し、コピー後にトークンへ寄せる手順もページ内に記載しています。",
    long: true,
  },
  {
    date: "2025.12.10",
    title: "Skills：実装ガイドの構成を整理",
    summary: "Layer規則とユーティリティの優先順位を冒頭に集約し、エージェントが参照しやすい見出し階層へ再編しました。",
    long: false,
  },
];
---

<Box id="news" class="z--news" pos="relative">
  <Frame isLayer>
    <Lism
      as="img"
      class="z--news_media"
      src={bg.src}
      alt={bg.alt}
      w="100%"
      h="100%"
      exProps={{ width: bg.width, height: bg.height, loading: "lazy", decoding: "async" }}
    />
  </Frame>
  <Layer style={{ filter: "grayscale(1)", backgroundColor: "hsl(224 4% 8% / 0.85)" }} />
  <Container isWrapper="m" py="60" set="gutter">
    <Stack g="40">
      <HGroup text="News" subText="お知らせ" variant="light" />
      <Stack g="20" c="white">
        {
          newsRows.map((row) => (
            <BoxLink class="z--news_item" href="#" layout="grid" gtc={["auto", "auto 1fr"]} g="20 40" py="15" set="hov">
              <Inline as="span">{row.date}</Inline>
              <Stack g="10">
                <Text as="p" hov="to:underline" td="none" m="0">
                  {row.title}
                </Text>
                <Text as="p" fz="s" o="-20" m="0">
                  {row.summary}
                  {row.long ? " 互換性に関する注意点はChangelogの該当バージョンにもまとめています。" : ""}
                </Text>
              </Stack>
            </BoxLink>
          ))
        }
      </Stack>
    </Stack>
  </Container>
</Box>

<style>
  .z--news {
    view-timeline: --z-news y;
  }
  .z--news .z--news_media {
    position: absolute;
    top: -20%;
    height: 140%;
    animation: z--news_media linear both;
    animation-timeline: --z-news;
    animation-range: entry 0% cover 100%;
  }
  @keyframes z--news_media {
    from {
      transform: translateY(-10%);
    }
    to {
      transform: translateY(10%);
    }
  }
  .z--news .z--news_item {
    view-timeline: --z-news_item y;
    animation: z--news_item linear both;
    animation-timeline: --z-news_item;
    animation-range: var(--u--fadeIn--animation-range);
  }
  @media (any-hover: hover) {
    .-hov\:to\:underline {
      text-decoration: var(--_isHov, underline);
    }
  }
  @keyframes z--news_item {
    from {
      opacity: 0;
      transform: translateX(-16px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
