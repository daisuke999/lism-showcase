---
import { Stack, Heading } from 'lism-css/astro';

interface Props {
  text: string;
  subText: string;
  variant?: 'light';
}

const { text, subText, variant } = Astro.props;
---

<Stack class:list={['z--p001-hgroup', { 'z--p001-hgroup--light': variant === 'light' }]} as='hgroup' ai='c' g='5'>
  <Heading level='2' class='z--p001-hgroup_heading' fz='3xl' fw='400' lts='l' m='0'>{text}</Heading>
  <Heading level='3' class='z--p001-hgroup_subHeading' d='inline-flex' ai='c' g='20' fz='s' fw='normal' lts='l' m='0'>
    {subText}
  </Heading>
</Stack>

<style>
  @layer lism-custom {

  .z--p001-hgroup {
    view-timeline: --z-hgroup y;
  }
  .z--p001-hgroup.z--p001-hgroup--light {
    color: var(--white);
  }
  .z--p001-hgroup .z--p001-hgroup_heading {
    animation: z--p001-hgroup_heading linear both;
    animation-timeline: --z-hgroup;
    animation-range: var(--u--fadeIn--animation-range);
  }
  @keyframes z--p001-hgroup_heading {
    from {
      opacity: 0;
      letter-spacing: 0.1em;
      text-indent: 0.1em;
      transform: translateY(32px);
    }
    to {
      opacity: 1;
      letter-spacing: var(--lts--l);
      text-indent: var(--lts--l);
      transform: translateY(0);
    }
  }
  .z--p001-hgroup .z--p001-hgroup_subHeading {
    position: relative;
    animation: z--p001-hgroup_heading linear both;
    animation-timeline: --z-hgroup;
    animation-range: var(--u--fadeIn--animation-range);
  }
  .z--p001-hgroup .z--p001-hgroup_subHeading:before,
  .z--p001-hgroup .z--p001-hgroup_subHeading:after {
    display: block;
    content: '';
    width: 12px;
    height: 1px;
    background-color: var(--text);
    transform-origin: center right;
    animation: z--p001-hgroup_subHeading_beforeAfter linear both;
    animation-timeline: --z-hgroup;
    animation-range: contain 25% contain 45%;
  }
  .z--p001-hgroup .z--p001-hgroup_subHeading:after {
    transform-origin: center left;
  }
  .z--p001-hgroup.z--p001-hgroup--light .z--p001-hgroup_subHeading:before,
  .z--p001-hgroup.z--p001-hgroup--light .z--p001-hgroup_subHeading:after {
    background-color: var(--white);
  }
  @keyframes z--p001-hgroup_subHeading_beforeAfter {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }

  }
</style>
