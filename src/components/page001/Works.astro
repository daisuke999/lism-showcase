---
import {
  Frame,
  Stack,
  Container,
  BoxLink,
  FluidCols,
  Layer,
  Center,
  Text,
  Heading,
  Inline,
  Lism,
} from 'lism-css/astro';
import HGroup from '@/components/page001/HGroup.astro';

const worksItems = [
  {
    n: 1,
    title: 'ドキュメントサイト刷新',
    body: 'ナビゲーションと検索を軸に、概要からカスタマイズまで辿りやすい情報設計へ再編。レスポンシブ切り替えのルールもページ内で再利用できる形に整理しました。',
  },
  {
    n: 2,
    title: 'デザインシステムLP',
    body: 'レイアウトプリミティブとトークン表を並べて、チーム内共有用のミニマルなランディングを制作。スクロール演出はページローカルのスタイルに閉じ込めています。',
  },
  {
    n: 3,
    title: 'ブログテンプレート適用',
    body: '記事一覧・詳細・著者情報の型をテンプレートから移植し、タグや関連記事の導線を軽量マークアップで実装。読み込み戦略は画像の遅延読み込みを前提に設計しました。',
  },
  {
    n: 4,
    title: 'UIコンポーネントギャラリー',
    body: 'AccordionやModalなどの挙動を、実装サンプルとあわせて一覧化。アクセシブルな開閉操作とフォーカス移動のパターンを揃えた展示ページです。',
  },
  {
    n: 5,
    title: 'コーポレートサイト再構築',
    body: 'セクションごとにStackとGridを切り替え、写真背景とオーバーレイのコントラストを調整。ブランドカラーはデザイントークンへ寄せて運用しやすくしています。',
  },
  {
    n: 6,
    title: '開発者向けオンボーディング',
    body: 'SkillsとMCPの導入手順を1ページに集約し、よくある設計判断（レイヤー・命名・レスポンシブ）へのリンクを配置。新メンバーの初日から迷いにくい構成です。',
  },
];

const shot = (n: number) => ({
  src: `https://cdn.lism-css.com/img/random-2510?r=works${n}`,
  alt: 'Beautiful Landscape',
  width: 960,
  height: 540,
});
---

<Container id='works' class='z--works' isWrapper='l' py='60' set='gutter'>
  <Stack g='40'>
    <HGroup text='Works' subText='制作実績' />
    <Text as='p' class='u--fadeIn' max-sz='full' mx='auto' m='0'>
      Lism CSSの設計思想に沿ったマークアップで組み上げた、公開用ランディングや社内向けツールの制作例です。
    </Text>
    <FluidCols cols='20rem' g='40'>
      {
        worksItems.map((item) => (
          <BoxLink class='z--works_item' href='#' layout='stack' set='hov'>
            <Frame class='z--works_frame' ar='16/9' pos='relative' bdrs='20'>
              <Lism
                as='img'
                class='z--works_media'
                src={shot(item.n).src}
                alt={shot(item.n).alt}
                w='100%'
                h='auto'
                set='transition'
                hov='to:zoom'
                exProps={{
                  width: shot(item.n).width,
                  height: shot(item.n).height,
                  loading: 'lazy',
                  decoding: 'async',
                }}
              />
              <Layer
                set='transition'
                hov='to:show'
                style={{
                  backgroundColor: 'rgb(0 0 0 / 30%)',
                  backdropFilter: 'blur(4px)',
                }}
              >
                <Center h='100%' c='white'>
                  <Inline as='span' fz='xl' fs='italic' fw='light' lts='l' px='20' py='10'>
                    View More
                  </Inline>
                </Center>
              </Layer>
            </Frame>
            <Stack g='15' py='20'>
              <Heading level='3' fz='m' m='0'>
                {item.title}
              </Heading>
              <Text as='p' fz='s' m='0' o='-10'>
                {item.body}
              </Text>
            </Stack>
          </BoxLink>
        ))
      }
    </FluidCols>
  </Stack>
</Container>

<style>
  .z--works .z--works_item {
    view-timeline: --z-works_item y;
    animation: z--works_item linear both;
    animation-timeline: --z-works_item;
    animation-range: var(--u--fadeIn--animation-range);
  }
  @keyframes z--works_item {
    from {
      transform: translateY(32px) scale(1.04);
      filter: blur(8px);
      opacity: 0;
    }
    to {
      transform: translateY(0) scale(1);
      filter: blur(0);
      opacity: 1;
    }
  }
  .z--works .z--works_frame {
    view-timeline: --z-works_frame y;
  }
  .z--works .z--works_media {
    animation: z--works_media linear both;
    animation-timeline: --z-works_frame;
    animation-range: var(--u--fadeIn--animation-range);
  }
  @keyframes z--works_media {
    from {
      transform: scale(1.2);
    }
    to {
      transform: scale(1);
    }
  }
  @media (any-hover: hover) {
    .-hov\:to\:zoom {
      scale: var(--_isHov, 1.1);
    }
  }
</style>
