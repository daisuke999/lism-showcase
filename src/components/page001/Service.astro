---
import { Frame, Stack, Container, Grid, Layer, Box, Text, Heading, Lism } from "lism-css/astro";
import HGroup from "@/components/page001/HGroup.astro";

const hero = {
  src: "https://cdn.lism-css.com/img/random-2510?r=service",
  alt: "",
  width: 960,
  height: 640,
};

const cardMedia = (r: string) => ({
  src: `https://cdn.lism-css.com/img/random-2510?r=${r}`,
  alt: "Beautiful Landscape",
  width: 960,
  height: 540,
});
---

<Box id="service" class="z--service" pos="relative">
  <Frame isLayer>
    <Lism
      as="img"
      class="z--service_media"
      src={hero.src}
      alt={hero.alt}
      w="100%"
      h="100%"
      exProps={{ width: hero.width, height: hero.height, loading: "lazy", decoding: "async" }}
    />
  </Frame>
  <Layer style={{ filter: "grayscale(1)", backgroundColor: "hsl(224 4% 99% / 0.85)" }} />
  <Container size="l" py="60" set="gutter">
    <Stack g="40">
      <HGroup text="Service" subText="サービス" />
      <Text as="p" class="u--fadeIn" max-sz="full" mx="auto" m="0">
        迅速なWeb開発を可能にするCSSフレームワークです。
      </Text>
      <Stack g="40">
        <Grid class="z--service_item" gtc={["auto", null, "2fr 3fr"]} cg="30">
          <Frame ar="16/9" pos="relative" bdrs="20">
            <Lism
              as="img"
              class="z--service_itemMedia"
              src={cardMedia("service1").src}
              alt={cardMedia("service1").alt}
              w="100%"
              h="100%"
              exProps={{
                width: cardMedia("service1").width,
                height: cardMedia("service1").height,
                loading: "lazy",
                decoding: "async",
              }}
            />
          </Frame>
          <Stack class="z--service_itemContent" g="10" max-w="36rem" py="20">
            <Heading level="3" fz="xl" m="0">Card Title</Heading>
            <Text as="p" m="0">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et
              dolore magna aliqua. Ut enim ad minim veniam
            </Text>
          </Stack>
        </Grid>
        <Grid class="z--service_item" gtc={["auto", null, "3fr 2fr"]} cg="30">
          <Frame ar="16/9" pos="relative" bdrs="20" gr={["auto", null, "1"]} gc={["auto", null, "2"]}>
            <Lism
              as="img"
              class="z--service_itemMedia"
              src={cardMedia("service2").src}
              alt={cardMedia("service2").alt}
              w="100%"
              h="100%"
              exProps={{
                width: cardMedia("service2").width,
                height: cardMedia("service2").height,
                loading: "lazy",
                decoding: "async",
              }}
            />
          </Frame>
          <Stack class="z--service_itemContent" g="10" max-w="36rem" py="20">
            <Heading level="3" fz="xl" m="0">Card Title</Heading>
            <Text as="p" m="0">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et
              dolore magna aliqua. Ut enim ad minim veniam
            </Text>
          </Stack>
        </Grid>
        <Grid class="z--service_item" gtc={["auto", null, "2fr 3fr"]} cg="30">
          <Frame ar="16/9" pos="relative" bdrs="20">
            <Lism
              as="img"
              class="z--service_itemMedia"
              src={cardMedia("service3").src}
              alt={cardMedia("service3").alt}
              w="100%"
              h="100%"
              exProps={{
                width: cardMedia("service3").width,
                height: cardMedia("service3").height,
                loading: "lazy",
                decoding: "async",
              }}
            />
          </Frame>
          <Stack class="z--service_itemContent" g="10" max-w="36rem" py="20">
            <Heading level="3" fz="xl" m="0">Card Title</Heading>
            <Text as="p" m="0">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et
              dolore magna aliqua. Ut enim ad minim veniam
            </Text>
          </Stack>
        </Grid>
        <Grid class="z--service_item" gtc={["auto", null, "3fr 2fr"]} cg="30">
          <Frame ar="16/9" pos="relative" bdrs="20" gr={["auto", null, "1"]} gc={["auto", null, "2"]}>
            <Lism
              as="img"
              class="z--service_itemMedia"
              src={cardMedia("service4").src}
              alt={cardMedia("service4").alt}
              w="100%"
              h="100%"
              exProps={{
                width: cardMedia("service4").width,
                height: cardMedia("service4").height,
                loading: "lazy",
                decoding: "async",
              }}
            />
          </Frame>
          <Stack class="z--service_itemContent" g="10" max-w="36rem" py="20">
            <Heading level="3" fz="xl" m="0">Card Title</Heading>
            <Text as="p" m="0">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et
              dolore magna aliqua. Ut enim ad minim veniam
            </Text>
          </Stack>
        </Grid>
      </Stack>
    </Stack>
  </Container>
</Box>

<style>
  .z--service {
    view-timeline: --z-service y;
  }
  .z--service .z--service_media {
    position: absolute;
    top: -20%;
    height: 140%;
    animation: z--service_media linear both;
    animation-timeline: --z-service;
    animation-range: entry 0% cover 100%;
  }
  @keyframes z--service_media {
    from {
      transform: translateY(-10%);
    }
    to {
      transform: translateY(10%);
    }
  }
  .z--service .z--service_item {
    view-timeline: --z-service_item y;
    animation: u--fadeIn linear both;
    animation-timeline: --z-service_item;
    animation-range: var(--u--fadeIn--animation-range);
  }
  .z--service .z--service_itemMedia {
    position: absolute;
    top: -20%;
    height: 140%;
    animation: z--service_itemMedia linear both;
    animation-timeline: --z-service_item;
    animation-range: entry 0% cover 100%;
  }
  @keyframes z--service_itemMedia {
    from {
      transform: translateY(-10%);
    }
    to {
      transform: translateY(10%);
    }
  }
  .z--service .z--service_item:nth-child(even) .z--service_itemContent {
    justify-self: end;
  }
</style>
