---
import { Stack, Container, BoxLink, Icon, Cluster, Text, Inline } from 'lism-css/astro';
---

<Container as='footer' isWrapper='m' py='40' hasGutter>
  <Stack jc='c' ai='c' g='30'>
    <Stack class='z--header_logo'>
      <Text as='p' fz='xl' fw='400' lts='l' m='0'>
        <Inline fw='200'>The</Inline>Minimal
      </Text>
    </Stack>
    <Cluster g='20'>
      <BoxLink href='#' hov='-o'>
        <Icon icon='logo-x' fz='l' c='text-2' />
      </BoxLink>
      <BoxLink href='#' hov='-o'>
        <Icon icon='logo-instagram' fz='l' c='text-2' />
      </BoxLink>
      <BoxLink href='#' hov='-o'>
        <Icon icon='logo-youtube' fz='l' c='text-2' />
      </BoxLink>
      <BoxLink href='#' hov='-o'>
        <Icon icon='logo-line' fz='l' c='text-2' />
      </BoxLink>
    </Cluster>
    <Text as='p' fz='s' c='text-2' m='0'>© 2026 The Minimal.</Text>
  </Stack>
</Container>
