---
import { Frame, Stack, Container, Box, Flow, Layer, Text, Lism } from 'lism-css/astro';
import HGroup from '@/components/page001/HGroup.astro';

const img = (r: string) => ({
  src: `https://cdn.lism-css.com/img/random-2510?r=${r}`,
  alt: 'Beautiful Landscape',
  width: 800,
  height: 600,
});

/** Feature セクションと同じオーバーレイ（filter + hsl、背後の写真に程よく色が残る） */
const aboutPhotoOverlay = {
  filter: 'grayscale(1)',
  backgroundColor: 'hsl(224 4% 99% / 0.85)',
};
---

<Container id='about' class='z--about' size='s' pos='relative' py='70' set='gutter'>
  <Stack ai='c' jc='c' g='40' pos='relative'>
    <HGroup text='About' subText='Lism CSSとは' />
    <Box class='z--about_visuals' pos='absolute' w='100%' h='100%' z='0'>
      <Frame class='z--about_frame' ar='4/3' pos='absolute' w='20rem' bgc='base-2' bdrs='20'>
        <Lism
          as='img'
          class='z--about_media'
          src={img('1').src}
          alt={img('1').alt}
          w='100%'
          h='100%'
          exProps={{ width: img('1').width, height: img('1').height, loading: 'lazy', decoding: 'async' }}
        />
        <Layer style={aboutPhotoOverlay} />
      </Frame>
      <Frame class='z--about_frame' ar='4/3' pos='absolute' w='16rem' bgc='base-2' bdrs='20'>
        <Lism
          as='img'
          class='z--about_media'
          src={img('2').src}
          alt={img('2').alt}
          w='100%'
          h='100%'
          exProps={{ width: img('2').width, height: img('2').height, loading: 'lazy', decoding: 'async' }}
        />
        <Layer style={aboutPhotoOverlay} />
      </Frame>
      <Frame class='z--about_frame' ar='4/3' pos='absolute' w='16rem' bgc='base-2' bdrs='20'>
        <Lism
          as='img'
          class='z--about_media'
          src={img('3').src}
          alt={img('3').alt}
          w='100%'
          h='100%'
          exProps={{ width: img('3').width, height: img('3').height, loading: 'lazy', decoding: 'async' }}
        />
        <Layer style={aboutPhotoOverlay} />
      </Frame>
    </Box>
    <Flow class='z--about_body u--fadeIn' flow='s' pos='relative' z='1'>
      <Text as='p' max-sz='full' mx='auto'>
        Lism CSSは、AIと人の両方が迷いにくい命名規則とレイヤー設計を軸にしたCSS設計フレームワークです。
        ファイルを一つ読み込むだけで導入でき、ビルド工程に縛られない軽量さが魅力です。
      </Text>
      <Text as='p' max-sz='full' mx='auto'>
        StackやFlex、Gridといったレイアウトプリミティブを組み合わせるだけで、ページの骨格を素早く組み立てられます。
        余白・タイポグラフィはハーモニックスケールに沿って整え、自然なリズムを保ちやすい設計になっています。
      </Text>
      <Text as='p' max-sz='full' mx='auto'>
        カラーや角丸、影などのデザイントークンはCSS変数で一元管理され、Property Class（例:
        -p:20）で意図を短く表現できます。
        @layerによるレイヤー構造で詳細度の衝突を抑え、チーム開発でも拡張しやすい土台を用意しています。
      </Text>
      <Text as='p' max-sz='full' mx='auto'>
        公式にはSkillsやMCPサーバー、UIコンポーネント、テンプレートなどのエコシステムも用意され、ドキュメントとあわせて学習コストを下げられます。
        本ページはその世界観を体験できるデモとして、代表的なセクション構成をまとめています。
      </Text>
    </Flow>
  </Stack>
</Container>

<style>
  .z--about {
    isolation: isolate;
    view-timeline: --z--about-timeline y;
    --z--about_range-start: 25%;
    --z--about_range-end: 20%;
  }
  .z--about .z--hgroup {
    position: relative;
    z-index: 1;
  }
  .z--about .z--about_visuals {
    pointer-events: none;
  }
  .z--about .z--about_frame {
    animation: z--about_frame linear both;
    animation-timeline: --z--about-timeline;
  }
  .z--about .z--about_frame:nth-child(1) {
    top: -2rem;
    right: 90%;
    animation-range: entry 0% cover 30%;
  }
  .z--about .z--about_frame:nth-child(2) {
    top: 6rem;
    left: 90%;
    animation-range: entry 20% cover 40%;
  }
  .z--about .z--about_frame:nth-child(3) {
    bottom: -6rem;
    right: 80%;
    animation-range: entry 40% cover 50%;
  }
  @container (min-width: 800px) {
    .z--about .z--about_frame:nth-child(1) {
      top: -2rem;
      right: calc(100% + 4rem);
    }
    .z--about .z--about_frame:nth-child(2) {
      top: 6rem;
      left: calc(100% + 4rem);
    }
    .z--about .z--about_frame:nth-child(3) {
      bottom: -6rem;
      right: calc(100% - 4rem);
    }
  }
  @keyframes z--about_frame {
    from {
      opacity: 0;
      filter: blur(16px);
      transform: scale(1.16);
    }
    to {
      opacity: 1;
      filter: blur(0);
      transform: scale(1);
    }
  }
  .z--about .z--about_media {
    animation: z--about_media linear both;
    animation-timeline: --z--about-timeline;
    animation-range: entry cover;
  }
  @keyframes z--about_media {
    from {
      transform: scale(1.2);
    }
    to {
      transform: scale(1);
    }
  }
</style>
