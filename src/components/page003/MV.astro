---
import { Stack, Container, Frame, Layer, Lism } from 'lism-css/astro';

const mvImage = {
  src: 'https://cdn.lism-css.com/img/japan/u-Dczv0Klww4.jpg',
  alt: '紅葉の庭園',
  width: 1920,
  height: 1080,
};
---

<Container
  as='section'
  pos='relative'
  w='100%'
  m='0'
  p='0'
  max-w='none'
  ov='clip'
  min-h='100svh'
>
  <Frame isLayer>
    <Lism
      as='img'
      src={mvImage.src}
      alt={mvImage.alt}
      w='100%'
      h='100%'
      exProps={{ width: mvImage.width, height: mvImage.height, loading: 'eager', fetchpriority: 'high' }}
    />
  </Frame>
  <Layer bgc='black:30%' exProps={{ 'aria-hidden': 'true' }} />
  <Stack
    pos='relative'
    ai='c'
    jc='c'
    g='0'
    w='100%'
    m='0'
    p='0'
    px='20'
    py-e='40'
    min-h='100svh'
    c='white'
    style={{ paddingBlockStart: 'calc(var(--z--header-height) + var(--s30))' }}
  >
    <Lism as='p' class='z--mv_copy' m='0'>
      <span class='z--mv_line'>都会の喧騒から離れ、</span>
      <span class='z--mv_line'>心安らぐ自然の中で</span>
      <span class='z--mv_line'>至福のひとときを。</span>
    </Lism>
  </Stack>
</Container>

<style>
  /* vertical-rl + 列方向 flex（Lism Props に無い組み合わせ） */
  .z--mv_copy {
    font-feature-settings: 'palt' 1;
    font-size: clamp(0.95rem, 2.8vw, 1.25rem);
    line-height: 1.85;
    letter-spacing: 0.22em;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    display: flex;
    flex-direction: column;
    flex-wrap: nowrap;
    align-items: stretch;
    gap: clamp(1.25rem, 3.5vw, 2.75rem);
  }
</style>
