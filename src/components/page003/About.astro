---
import { Stack, Lism, Text, Heading, Grid, Frame } from 'lism-css/astro';

const imgLeft = {
  src: 'https://cdn.lism-css.com/img/japan/u-qQGCFQFlkT.jpg',
  alt: '池を泳ぐ鯉',
  width: 1920,
  height: 1280,
};
const imgRight = {
  src: 'https://cdn.lism-css.com/img/japan/u-lCzkkcbJUb.jpg',
  alt: '座敷から望む秋の庭園',
  width: 1600,
  height: 1200,
};

const bodyCopy =
  '百余年の歴史を刻む、風格ある佇まい。古き良き日本の情緒を残しつつ、現代の快適さを融合させた空間で皆様をお迎えいたします。手入れの行き届いた日本庭園を眺め、静寂に包まれて味わう名湯は、格別な癒やし。受け継がれてきたおもてなしの心で、特別な旅を鮮やかに彩ります。';
---

<Lism
  as='section'
  id='about'
  class='z--p003-about'
  isContainer
  py-s='50'
  py-e='60'
  bgc='black'
  c='white'
>
  <Grid
    class='z--p003-about_grid'
    gtc={['1fr', '1fr', 'minmax(0, calc(50vw - 96px)) minmax(0, 1fr)']}
    cg='0'
    rg={['30', '30', '0']}
    ai='start'
  >
    <Stack class='z--p003-about_col z--p003-about_col--left' g={['30', '30', '40']} px-e={['0', '0', '40']}>
      <Stack class='z--p003-about_stack' g='0' ai='start'>
        <Text as='p' fz='s' m='0' mb='10' lts='w' tt='upper' ff='base' c='white' o='pp'>
          About us
        </Text>
        <Heading level='2' fz={['2xl', null, '4xl']} fw='500' m='0' mb='50' lts='l'>
          当宿について
        </Heading>
        <Text as='p' m='0' fz='m' lh='l' lts='s' c='white' o='p'>
          {bodyCopy}
        </Text>
      </Stack>
      <Frame as='figure' class='z--p003-about_figureLeft' m='0' ar={['16/10', '16/10', '4/3']} ov='hidden'>
        <img
          src={imgLeft.src}
          alt={imgLeft.alt}
          width={imgLeft.width}
          height={imgLeft.height}
          loading='lazy'
          decoding='async'
        />
      </Frame>
    </Stack>
    <Lism as='figure' class='z--p003-about_figureRight' m='0'>
      <Lism
        as='img'
        class='z--p003-about_mediaRightImg'
        src={imgRight.src}
        alt={imgRight.alt}
        exProps={{ width: imgRight.width, height: imgRight.height, loading: 'lazy', decoding: 'async' }}
      />
    </Lism>
  </Grid>
</Lism>

<script>
  const syncAboutRightMaxHeight = () => {
    const root = document.getElementById('about');
    const left = root?.querySelector('.z--p003-about_col--left') as HTMLElement | null | undefined;
    const figureRight = root?.querySelector('.z--p003-about_figureRight') as HTMLElement | null | undefined;
    if (!root || !left || !figureRight) return;
    const mq = window.matchMedia('(min-width: 800px)');
    if (!mq.matches) {
      figureRight.style.removeProperty('--p003-about-right-max-h');
      return;
    }
    figureRight.style.setProperty('--p003-about-right-max-h', `${left.offsetHeight}px`);
  };

  syncAboutRightMaxHeight();
  window.addEventListener('resize', syncAboutRightMaxHeight);
  document.addEventListener('astro:page-load', syncAboutRightMaxHeight);
  const aboutLeftEl = document.getElementById('about')?.querySelector('.z--p003-about_col--left');
  if (aboutLeftEl && typeof ResizeObserver !== 'undefined') {
    new ResizeObserver(syncAboutRightMaxHeight).observe(aboutLeftEl);
  }
</script>

<style>
  /*
   * ビューポート全幅: 親の max-width に依存しないよう、自身を 100vw で中央に置く。
   */
  .z--p003-about {
    --p003-about-l-inset: max(var(--gutter-size), calc((100vw - var(--sz--l)) / 2));
    --p003-about-xl-inset: max(var(--gutter-size), calc((100vw - var(--sz--xl)) / 2));
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    box-sizing: border-box;
    width: 100vw;
    max-width: 100vw;
    overflow-x: clip;
  }
  .z--p003-about_mediaRightImg {
    display: block;
    inline-size: 100%;
    object-fit: cover;
  }
  @media (min-width: 800px) {
    .z--p003-about_col--left {
      box-sizing: border-box;
      min-width: 0;
      /* 見出し・本文: グローバルな size=l の左端（Lism の px-s はカスタム計算のため CSS のみ） */
      padding-inline-start: var(--p003-about-l-inset);
    }
    .z--p003-about_stack {
      align-self: start;
      width: min(100%, var(--sz--l));
      min-width: 0;
    }
    /* 左メディア: xl 左に寄せつつ、グリッドセル幅を超えない */
    .z--p003-about_figureLeft {
      align-self: start;
      margin-block-start: auto;
      margin-inline-start: calc(var(--p003-about-xl-inset) - var(--p003-about-l-inset));
      box-sizing: border-box;
      min-inline-size: 0;
      max-inline-size: 100%;
      inline-size: min(20rem, 100%);
    }
    /* 右メディア: 左カラムの実高を上限（--p003-about-right-max-h は script で付与） */
    .z--p003-about_figureRight {
      align-self: start;
      box-sizing: border-box;
      block-size: var(--p003-about-right-max-h, auto);
      max-block-size: var(--p003-about-right-max-h, min(70vh, 48rem));
      overflow: hidden;
      line-height: 0;
    }
    .z--p003-about_mediaRightImg {
      block-size: 100%;
      max-block-size: 100%;
      inline-size: 100%;
      object-fit: cover;
    }
  }
  /* Lism の md は 800px 未満（prop-responsive.md） */
  @media (max-width: 799px) {
    /* グリッドのガターはトークン外の --gutter-size のためメディアクエリで維持 */
    .z--p003-about_grid {
      padding-inline: var(--gutter-size);
      box-sizing: border-box;
    }
    .z--p003-about_figureLeft {
      inline-size: 100%;
      max-inline-size: none;
    }
    .z--p003-about_mediaRightImg {
      aspect-ratio: 4 / 3;
      block-size: auto;
    }
  }
</style>
