---
import { Inline } from 'lism-css/astro';
import { Button } from '@lism-css/ui/astro';
---

<Button
  class='z--reservationFab'
  href='#reservation'
  pos='fixed'
  z='60'
  layout='flex'
  fxd='column'
  ai='center'
  jc='center'
  g='4'
  py='10'
  px='20'
  bdrs='99'
  bd
  bdc='white'
  bgc='black'
  c='white'
  bxsh='20'
  set='var:bxsh'
  td='none'
  fz='s'
  lts='s'
  ta='center'
  style={{
    right: 'max(var(--s20), env(safe-area-inset-right))',
    bottom: 'max(var(--s20), env(safe-area-inset-bottom))',
  }}
>
  <Inline as='span' m='0' fz='s' fw='500' lts='s'>
    ご予約はこちら
  </Inline>
  <Inline as='span' m='0' fz='2xs' o='pp' lts='l'>
    Reservation
  </Inline>
</Button>

<style>
  /* ピル型 FAB: UI Button のセマンティック色を上書き */
  .z--reservationFab.c--button {
    --bgc: var(--black);
    --c: var(--white);
    --bdc: var(--white);
  }
  .z--reservationFab:focus-visible {
    outline: 2px solid var(--white);
    outline-offset: 3px;
  }
</style>
